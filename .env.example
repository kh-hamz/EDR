# Copy to .env and fill in real values. .env is gitignored, never commit it.

# --- Postgres (metadata DB: agents, alerts, incidents, commands) ---
POSTGRES_USER=edr
POSTGRES_PASSWORD=change-me
POSTGRES_DB=edr
POSTGRES_PORT=5432

# --- OpenSearch (hot event store) ---
OPENSEARCH_PORT=9200
OPENSEARCH_URL=http://localhost:9200

# --- OpenSearch Dashboards (hunting UI, the roadmap's "Kibana") ---
DASHBOARDS_PORT=5601

# --- Redis (stream bus between ingest and pipeline workers) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- Used from Phase 3 onward ---
EDR_INDEX_PREFIX=edr-events

# --- API auth (Phase 1+) ---
# Shared bearer token: backend checks it, agent sends it (as EDR_AGENT_API_TOKEN).
# Generate with: openssl rand -hex 24
EDR_API_TOKEN=change-me

# --- Used from Phase 6 onward (AI copilot) ---
# LLM_API_KEY=
